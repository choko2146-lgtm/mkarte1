<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Mkarte1" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/mkarte_primary</item>
        <item name="colorPrimaryVariant">@color/mkarte_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/mkarte_accent_soft</item>
        <item name="colorSecondaryVariant">@color/mkarte_accent</item>
        <item name="colorOnSecondary">@color/mkarte_text</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/mkarte_background</item>
        <item name="android:fontFamily">sans</item>
        <!-- Customize your theme here. -->
    </style>
</resources>
