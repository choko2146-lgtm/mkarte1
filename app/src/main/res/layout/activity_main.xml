<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mkarte_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/mkarte_screen_padding">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="おかんのカルテ"
            android:textColor="@color/mkarte_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text="顧客と写真をやさしく整理"
            android:textColor="@color/mkarte_text_subtle"
            android:textSize="15sp" />

        <Button
            android:id="@+id/buttonCamera"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="@dimen/mkarte_item_gap"
            android:background="@drawable/bg_button_primary"
            android:elevation="1dp"
            android:text="カメラ"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <Button
            android:id="@+id/buttonCustomerRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="@dimen/mkarte_item_gap"
            android:background="@drawable/bg_button_secondary"
            android:elevation="1dp"
            android:text="顧客登録"
            android:textColor="@color/mkarte_text"
            android:textSize="18sp" />

        <Button
            android:id="@+id/buttonCustomerList"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="@dimen/mkarte_item_gap"
            android:background="@drawable/bg_button_secondary"
            android:elevation="1dp"
            android:text="顧客一覧"
            android:textColor="@color/mkarte_text"
            android:textSize="18sp" />

        <Button
            android:id="@+id/buttonCalendar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="@dimen/mkarte_item_gap"
            android:background="@drawable/bg_button_secondary"
            android:elevation="1dp"
            android:text="&#12459;&#12524;&#12531;&#12480;&#12540;"
            android:textColor="@color/mkarte_text"
            android:textSize="18sp" />

        <Button
            android:id="@+id/buttonPhotoList"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_button_secondary"
            android:elevation="1dp"
            android:text="写真一覧"
            android:textColor="@color/mkarte_text"
            android:textSize="18sp" />
    </LinearLayout>
</ScrollView>
