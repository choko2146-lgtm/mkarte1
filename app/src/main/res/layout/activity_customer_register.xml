<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mkarte_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/mkarte_screen_padding">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="顧客情報"
            android:textColor="@color/mkarte_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="顧客名（必須）"
            android:inputType="textPersonName"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/mkarte_text"
            android:textColorHint="@color/mkarte_text_subtle" />

        <EditText
            android:id="@+id/editKana"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="フリガナ"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/mkarte_text"
            android:textColorHint="@color/mkarte_text_subtle" />

        <EditText
            android:id="@+id/editPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="電話番号"
            android:inputType="phone"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/mkarte_text"
            android:textColorHint="@color/mkarte_text_subtle" />

        <EditText
            android:id="@+id/editPostalCode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="郵便番号"
            android:inputType="textPostalAddress"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/mkarte_text"
            android:textColorHint="@color/mkarte_text_subtle" />

        <EditText
            android:id="@+id/editAddress"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="住所"
            android:inputType="textPostalAddress"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/mkarte_text"
            android:textColorHint="@color/mkarte_text_subtle" />

        <EditText
            android:id="@+id/editMemo"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="メモ"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/mkarte_text"
            android:textColorHint="@color/mkarte_text_subtle" />

        <Button
            android:id="@+id/buttonSave"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mkarte_button_height"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:text="登録する"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/buttonBack"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mkarte_button_height"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="戻る"
            android:textColor="@color/mkarte_text" />
    </LinearLayout>
</ScrollView>
