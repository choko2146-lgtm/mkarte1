<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mkarte_background"
    android:orientation="vertical"
    android:padding="@dimen/mkarte_screen_padding">

    <ImageView
        android:id="@+id/imagePreview"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_card"
        android:contentDescription="撮影写真"
        android:elevation="1dp"
        android:padding="4dp"
        android:scaleType="centerCrop" />

    <EditText
        android:id="@+id/editSearch"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input"
        android:hint="顧客名・フリガナ・電話番号で検索"
        android:inputType="text"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:singleLine="true"
        android:textColor="@color/mkarte_text"
        android:textColorHint="@color/mkarte_text_subtle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCustomers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/buttonNewCustomer"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mkarte_button_height"
        android:background="@drawable/bg_button_secondary"
        android:text="新規顧客登録"
        android:textColor="@color/mkarte_text" />

    <Button
        android:id="@+id/buttonLink"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mkarte_button_height"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_primary"
        android:text="この顧客に紐づける"
        android:textColor="@color/white" />
</LinearLayout>
