<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/black">

        <ImageView
            android:id="@+id/imagePhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:background="@android:color/black"
            android:contentDescription="写真"
            android:scaleType="fitCenter" />

        <Button
            android:id="@+id/buttonPreviousPhoto"
            android:layout_width="56dp"
            android:layout_height="72dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:background="#66000000"
            android:text="‹"
            android:textColor="@color/white"
            android:textSize="34sp" />

        <Button
            android:id="@+id/buttonNextPhoto"
            android:layout_width="56dp"
            android:layout_height="72dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="8dp"
            android:background="#66000000"
            android:text="›"
            android:textColor="@color/white"
            android:textSize="34sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/mkarte_background"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/textPhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:textColor="@color/mkarte_text"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/editMemo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="写真メモ"
            android:inputType="textMultiLine"
            android:padding="10dp"
            android:textColor="@color/mkarte_text"
            android:textColorHint="@color/mkarte_text_subtle"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonSaveMemo"
                android:layout_width="0dp"
                android:layout_height="@dimen/mkarte_button_height"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="メモを保存"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/buttonDeletePhoto"
                android:layout_width="0dp"
                android:layout_height="@dimen/mkarte_button_height"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_danger"
                android:text="写真を削除"
                android:textColor="@color/mkarte_danger" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
